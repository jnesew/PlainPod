{
  "id": "io.github.jnesew.PlainPod",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.10",
  "sdk": "org.kde.Sdk",
  "base": "io.qt.PySide.BaseApp",
  "base-version": "6.10",
  "command": "plainpod",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=pulseaudio",
    "--share=network",
    "--filesystem=xdg-download",
    "--own-name=org.mpris.MediaPlayer2.io.github.jnesew.PlainPod",
    "--talk-name=org.kde.StatusNotifierWatcher",
    "--talk-name=org.freedesktop.DBus"
  ],
  "modules": [                                                                                         
    {
        "name": "python3-dbus-next",
        "buildsystem": "simple",
        "build-commands": [
            "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} \"dbus-next\" --no-build-isolation"
        ],
        "sources": [
            {
                "type": "file",
                "url": "https://files.pythonhosted.org/packages/d2/fc/c0a3f4c4eaa5a22fbef91713474666e13d0ea2a69c84532579490a9f2cc8/dbus_next-0.2.3-py3-none-any.whl",
                "sha256": "58948f9aff9db08316734c0be2a120f6dc502124d9642f55e90ac82ffb16a18b"
            }
        ]
    },  {
      "name": "plainpod",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-build-isolation --prefix=/app .",
        "install -Dm644 io.github.jnesew.PlainPod.desktop /app/share/applications/io.github.jnesew.PlainPod.desktop",
        "install -Dm644 io.github.jnesew.PlainPod.metainfo.xml /app/share/metainfo/io.github.jnesew.PlainPod.metainfo.xml",
        "install -Dm644 io.github.jnesew.PlainPod.svg /app/share/icons/hicolor/scalable/apps/io.github.jnesew.PlainPod.svg"
      ],
      "sources": [
        {
          "type": "archive",
          "path": "dist/plainpod-0.1.0.tar.gz"
        },
        {
          "type": "file",
          "path": "io.github.jnesew.PlainPod.desktop"
        },
        {
          "type": "file",
          "path": "io.github.jnesew.PlainPod.metainfo.xml"
        },
        {
          "type": "file",
          "path": "io.github.jnesew.PlainPod.svg"
        }
      ]
    }
  ],
  "cleanup-commands": [
    "/app/cleanup-BaseApp.sh"
  ]
}